          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/lessons/{{lessonId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","lessons","{{lessonId}}"]}
          }
        },
        {
          "name": "[Instructor] Post announcement",
