          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{studentToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/announcements","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","announcements"]}
          }
