    {
      "name": "04 — Enrolment Service (8084)",
      "item": [
        {
          "name": "[Student] Enrol in course",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.enrollmentId) pm.collectionVariables.set('enrollmentId', r.enrollmentId);"]}}],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{studentToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"courseId\": {{courseId}},\n  \"paymentToken\": null\n}"},
            "url": {"raw": "http://{{host}}:8084/api/v1/enrollments","protocol": "http","host": ["{{host}}"],"port": "8084","path": ["api","v1","enrollments"]}
          }
        },
        {
          "name": "[Student/Admin] List a student's enrolments",
