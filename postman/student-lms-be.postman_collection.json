{
  "info": {
    "name": "Student LMS Backend",
    "description": "All 8 service endpoints with chained variables. Run folder 00 first to register + login the three personas (admin, instructor, student). Then exercise the services in any order — tokens and IDs are auto-extracted into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 — Setup (run first)",
      "item": [
        {
          "name": "0.1 Register Admin",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.userId) pm.collectionVariables.set('adminId', r.userId);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"role\": \"ADMIN\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/register","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","register"]}
          }
        },
        {
          "name": "0.2 Register Instructor",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.userId) pm.collectionVariables.set('instructorId', r.userId);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"{{instructorUsername}}\",\n  \"password\": \"{{instructorPassword}}\",\n  \"email\": \"{{instructorEmail}}\",\n  \"role\": \"INSTRUCTOR\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/register","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","register"]}
          }
        },
        {
          "name": "0.3 Register Student",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.userId) pm.collectionVariables.set('studentId', r.userId);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"{{studentUsername}}\",\n  \"password\": \"{{studentPassword}}\",\n  \"email\": \"{{studentEmail}}\",\n  \"role\": \"STUDENT\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/register","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","register"]}
          }
        },
        {
          "name": "0.4 Login Admin",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.accessToken) {","  pm.collectionVariables.set('adminToken', r.accessToken);","  pm.collectionVariables.set('adminRefreshToken', r.refreshToken);","  if (r.userId) pm.collectionVariables.set('adminId', r.userId);","}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/login","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","login"]}
          }
        },
        {
          "name": "0.5 Login Instructor",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.accessToken) {","  pm.collectionVariables.set('instructorToken', r.accessToken);","  pm.collectionVariables.set('instructorRefreshToken', r.refreshToken);","  if (r.userId) pm.collectionVariables.set('instructorId', r.userId);","}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{instructorEmail}}\",\n  \"password\": \"{{instructorPassword}}\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/login","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","login"]}
          }
        },
        {
          "name": "0.6 Login Student",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.accessToken) {","  pm.collectionVariables.set('studentToken', r.accessToken);","  pm.collectionVariables.set('studentRefreshToken', r.refreshToken);","  if (r.userId) pm.collectionVariables.set('studentId', r.userId);","}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/login","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","login"]}
          }
        }
      ]
    },
    {
      "name": "01 — Auth Service (8081)",
      "item": [
        {
          "name": "Refresh student token",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.accessToken) {","  pm.collectionVariables.set('studentToken', r.accessToken);","  pm.collectionVariables.set('studentRefreshToken', r.refreshToken);","}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"{{studentRefreshToken}}\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/refresh","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","refresh"]}
          }
        },
        {
          "name": "Logout student",
          "request": {
            "method": "POST",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{studentToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"{{studentRefreshToken}}\"\n}"},
            "url": {"raw": "http://{{host}}:8081/api/v1/auth/logout","protocol": "http","host": ["{{host}}"],"port": "8081","path": ["api","v1","auth","logout"]}
          }
        }
      ]
    },
    {
      "name": "02 — User Service (8082)",
      "item": [
        {
          "name": "Get own profile (Student)",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{studentToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8082/api/v1/users/{{studentId}}","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","users","{{studentId}}"]}
          }
        },
        {
          "name": "Update own profile (Student)",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{studentToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"john_doe_updated\",\n  \"email\": \"john.updated@lms.com\"\n}"},
            "url": {"raw": "http://{{host}}:8082/api/v1/users/{{studentId}}","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","users","{{studentId}}"]}
          }
        },
        {
          "name": "[Admin] List users",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8082/api/v1/admin/users?role=STUDENT&active=true&size=20","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","admin","users"],"query": [{"key": "role","value": "STUDENT"},{"key": "active","value": "true"},{"key": "size","value": "20"},{"key": "search","value": "","disabled": true}]}
          }
        },
        {
          "name": "[Admin] Get user by id",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8082/api/v1/admin/users/{{studentId}}","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","admin","users","{{studentId}}"]}
          }
        },
        {
          "name": "[Admin] Change role",
          "request": {
            "method": "PATCH",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"role\": \"INSTRUCTOR\"\n}"},
            "url": {"raw": "http://{{host}}:8082/api/v1/admin/users/{{studentId}}/role","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","admin","users","{{studentId}}","role"]}
          }
        },
        {
          "name": "[Admin] Deactivate user",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8082/api/v1/admin/users/{{studentId}}","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","admin","users","{{studentId}}"]}
          }
        },
        {
          "name": "[Admin] Reactivate user",
          "request": {
            "method": "PATCH",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8082/api/v1/admin/users/{{studentId}}/reactivate","protocol": "http","host": ["{{host}}"],"port": "8082","path": ["api","v1","admin","users","{{studentId}}","reactivate"]}
          }
        }
      ]
    },
    {
      "name": "03 — Course Service (8083)",
      "item": [
        {
          "name": "[Public] List published courses",
          "request": {
            "method": "GET",
            "url": {"raw": "http://{{host}}:8083/api/v1/courses?category=Backend&difficulty=BEGINNER&size=20","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses"],"query": [{"key": "category","value": "Backend"},{"key": "difficulty","value": "BEGINNER"},{"key": "size","value": "20"},{"key": "search","value": "","disabled": true},{"key": "instructorId","value": "","disabled": true},{"key": "maxPrice","value": "","disabled": true}]}
          }
        },
        {
          "name": "[Public] Get course by id",
          "request": {
            "method": "GET",
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}"]}
          }
        },
        {
          "name": "[Instructor] Create course (DRAFT)",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.courseId) pm.collectionVariables.set('courseId', r.courseId);"]}}],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Spring Boot Fundamentals\",\n  \"description\": \"Learn Spring Boot from scratch — controllers, services, JPA, security.\",\n  \"category\": \"Backend\",\n  \"difficulty\": \"BEGINNER\",\n  \"price\": 0.00,\n  \"duration\": 12\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses"]}
          }
        },
        {
          "name": "[Instructor] Update course",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"description\": \"Updated description — now covers Spring Boot 3.x specifically.\",\n  \"duration\": 15\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}"]}
          }
        },
        {
          "name": "[Instructor] Submit course for approval",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"action\": \"SUBMIT\"\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/publish","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","publish"]}
          }
        },
        {
          "name": "[Admin] Approve course",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"action\": \"APPROVE\"\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/publish","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","publish"]}
          }
        },
        {
          "name": "[Admin] Reject course (PENDING → DRAFT)",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"action\": \"REJECT\"\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/publish","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","publish"]}
          }
        },
        {
          "name": "[Owner/Admin] Archive course",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}"]}
          }
        },
        {
          "name": "[Admin] Restore archived course",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"action\": \"RESTORE\"\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/publish","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","publish"]}
          }
        },
        {
          "name": "List modules in course",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/courses/{{courseId}}/modules","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","courses","{{courseId}}","modules"]}
          }
        },
        {
          "name": "[Instructor] Create module",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.moduleId) pm.collectionVariables.set('moduleId', r.moduleId);"]}}],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"courseId\": {{courseId}},\n  \"title\": \"Getting Started\",\n  \"orderIndex\": 0\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/modules","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","modules"]}
          }
        },
        {
          "name": "[Instructor] Update module",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Getting Started (Revised)\",\n  \"orderIndex\": 1\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/modules/{{moduleId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","modules","{{moduleId}}"]}
          }
        },
        {
          "name": "[Instructor] Delete module",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/modules/{{moduleId}}","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","modules","{{moduleId}}"]}
          }
        },
        {
          "name": "List lessons in module",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "url": {"raw": "http://{{host}}:8083/api/v1/modules/{{moduleId}}/lessons","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","modules","{{moduleId}}","lessons"]}
          }
        },
