          "name": "[Instructor] Create lesson",
          "event": [{"listen": "test","script": {"type": "text/javascript","exec": ["const r = pm.response.json();","if (r && r.lessonId) pm.collectionVariables.set('lessonId', r.lessonId);"]}}],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"moduleId\": {{moduleId}},\n  \"title\": \"Hello Spring\",\n  \"contentType\": \"TEXT\",\n  \"contentUrl\": \"https://example.com/lessons/hello-spring.md\",\n  \"duration\": null,\n  \"orderIndex\": 0\n}"},
            "url": {"raw": "http://{{host}}:8083/api/v1/lessons","protocol": "http","host": ["{{host}}"],"port": "8083","path": ["api","v1","lessons"]}
          }
        },
        {
          "name": "[Instructor] Update lesson",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{instructorToken}}","type": "string"}]},
